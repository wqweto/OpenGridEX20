                        [in, out, optional, defaultvalue(-1)] VARIANT_BOOL* Rebind, 
                        [in, optional] BSTR DatabaseName);
        [id(0x60030070), helpstring("Set focus to the specific record box in the record navigator.")]
        HRESULT SetFocusRecordNavigator();
        [id(0x60030071), helpstring("Forces a GridEX control to refresh its contents without re-opening the recordset. ")]
        HRESULT Refetch([in, out, optional] VARIANT* HoldSortSettings);
        [id(0x60030072), helpstring("Prints the contents of a GridEX control.")]
        HRESULT PrintGrid(
                        [in, out, optional] VARIANT_BOOL* UsePrintSetupDlg, 
                        [in, out, optional] VARIANT_BOOL* PrintSelectedItems);
        [id(0x60030073), helpstring("Loads a previously saved GridEX layout from a file.")]
        HRESULT LoadLayout(
                        [in] BSTR FileName, 
                        [in, out, optional, defaultvalue(-1)] VARIANT_BOOL* Rebind, 
                        [in, optional] BSTR DatabaseName);
        [id(0x60030074), helpstring("Initiates an OLE drag/drop operation.")]
        HRESULT OLEDrag();
        [id(0x60030075), helpstring("Collapses all group rows.")]
        HRESULT CollapseAll();
        [id(0x60030076), helpstring("Forces the re-sort of the records.")]
        HRESULT RefreshSort();
        [id(0x60030077), helpstring("Returns the original index of a row.")]
        HRESULT RowIndex(
                        [in] long RowPosition, 
                        [out, retval] long* );
        [id(0x60030078), helpstring("Forces recalculation of groups.")]
        HRESULT RefreshGroups([in, optional] VARIANT_BOOL AllCollapsed);
        [id(0x60030079), helpstring("Ensures visibility of a cell.")]
        HRESULT EnsureVisible(
                        [in, optional] long Row, 
                        [in, optional] short Col);
        [id(0x6003007a), helpstring("Forces re-creation of the recordset.")]
        HRESULT Rebind([in, out, optional] VARIANT* HoldSortSettings);
        [id(0x6003007b), helpstring("Returns True if the specified row is a group row.")]
        HRESULT IsGroupItem(
                        [in] long Row, 
                        [out, retval] VARIANT_BOOL* );
        [id(0x6003007c), helpstring("Forces a complete repaint of a GridEX control.")]
        HRESULT Refresh();
        [id(0x6003007d), helpstring("Prevents recalculation of the column layout when the recordset is created.")]
        HRESULT HoldFields();
        [id(0x6003007e), helpstring("Restores the default layout columns.")]
        HRESULT ClearFields();
        [id(0xfffffdd8), helpstring("Displays the About box for the control.")]
        HRESULT AboutBox();
        [id(0x6003007f), helpstring("Loads the bookmarks of all records in the underlying Recordset.")]
        HRESULT LoadEntireRecordset();
        [id(0x60030080), helpstring("Expands all group rows.")]
        HRESULT ExpandAll();
        [id(0x60030081), helpstring("Returns the part of a GridEX control that contains the specified point.")]
        HRESULT HitTest(
                        [in] long X, 
                        [in] long Y, 
                        [out, retval] jgexHitTestConstants* );
        [id(0x60030082), helpstring("Returns a JSColumn object that contains a given point.")]
        HRESULT ColFromPoint(
                        [in] long X, 
                        [in] long Y, 
                        [out, retval] _JSColumn** );
        [id(0x60030083), helpstring("Returns the row that contains the given point.")]
        HRESULT RowFromPoint(
                        [in] long X, 
                        [in] long Y, 
                        [out, retval] long* );
        [id(0x60030084), helpstring("Sets the current row as the one that matches the Bookmark.")]
        HRESULT MoveToBookmark([in] VARIANT vBookmark);
        [id(0x60030085), helpstring("Sets the current row as the one that matches the index.")]
        HRESULT MoveToRowIndex([in] long RowIndex);
        [id(0x60030086), helpstring("Commit changes made to the current row writing to the database and re-position the record in case that needed.")]
        HRESULT Update();
        [id(0x60030087), helpstring("Sets the first open record as the current row.")]
        HRESULT MoveFirst();
        [id(0x60030088), helpstring("Sets the last open record as the current row.")]
        HRESULT MoveLast();
        [id(0x60030089), helpstring("Moves to the previous open record.")]
        HRESULT MovePrevious();
        [id(0x6003008a), helpstring("Moves to the next open record.")]
        HRESULT MoveNext();
        [id(0x6003008b), helpstring("Moves the current row to the specified position.")]
        HRESULT MoveRelative([in] long nRows);
        [id(0x6003008c), helpstring("Deletes selected rows.")]
        HRESULT Delete();
        [id(0x6003008d), helpstring("Searches for records added after all bookmarks have been loaded.")]
        HRESULT SearchNewRecords();
        [id(0x6003008e), helpstring("Refreshes data of the record that matches the Bookmark.")]
        HRESULT RefreshRowBookmark([in] VARIANT Bookmark);
        [id(0x6003008f), helpstring("Refreshes data of the record that matches the index.")]
        HRESULT RefreshRowIndex([in] long RowIndex);
        [id(0x60030090), helpstring("Returns the level of a group row.")]
        HRESULT GroupRowLevel(
                        [in] long RowPosition, 
                        [out, retval] short* );
        [id(0x60030091), helpstring("Expands and selects children records of selected group rows.")]
        HRESULT ExpandSelection();
        [id(0x60030092), helpstring("Returns the contents of the selected rows.")]
        HRESULT GetClipString(
                        [in, optional] VARIANT_BOOL IncludeHeaders, 
                        [in, optional] BSTR ColumnDelimeter, 
                        [in, optional] BSTR RowDelimeter, 
                        [out, retval] BSTR* );
        [id(0x60030093), helpstring("Returns True if a cell is visible.")]
        HRESULT CellVisible(
                        [in, out, optional] long* RowPosition, 
                        [in, out, optional] short* ColPosition, 
                        [out, retval] VARIANT_BOOL* );
        [id(0x60030094), helpstring("Returns the left of a cell.")]
        HRESULT CellLeft(
                        [in, out, optional] long* RowPosition, 
                        [in, out, optional] short* ColPosition, 
                        [out, retval] long* );
        [id(0x60030095), helpstring("Returns the top of a cell.")]
        HRESULT CellTop(
                        [in, out, optional] long* RowPosition, 
                        [in, out, optional] short* ColPosition, 
                        [out, retval] long* );
        [id(0x60030096), helpstring("Returns the width of a cell.")]
        HRESULT CellWidth(
                        [in, out, optional] long* RowPosition, 
                        [in, out, optional] short* ColPosition, 
                        [out, retval] long* );
        [id(0x60030097), helpstring("Returns the height of a cell.")]
        HRESULT CellHeight(
                        [in, out, optional] long* RowPosition, 
                        [in, out, optional] short* ColPosition, 
                        [out, retval] long* );
        [id(0x60030098), helpstring("Sets the current row to the one that matches the specified criteria.")]
        HRESULT Find(
                        [in] short ColIndex, 
                        [in] jgexConditionOperatorConstants Operator, 
                        [in] VARIANT Value1, 
                        [in, optional] VARIANT Value2, 
                        [in, out, optional, defaultvalue(-1)] long* Start, 
                        [in, out, optional] long* SearchDirection, 
                        [out, retval] VARIANT_BOOL* );
        [id(0x60030099), helpstring("Saves the current GridEX layout in a file.")]
        HRESULT SaveLayout([in] BSTR FileName);
        [id(0x6003009a), helpstring("Sends the contents of a GridEX control to be printed to a GEXPreview control.")]
        HRESULT PrintPreview(
                        [in, out] IDispatch** PreviewControl, 
                        [in, out, optional] VARIANT_BOOL* PrintSelectedItems);
        [id(0x6003009b), helpstring("Returns the JSGroup object in the specified coordinates.")]
        HRESULT GroupFromPoint(
                        [in] long X, 
                        [in] long Y, 
                        [out, retval] _JSGroup** );
        [id(0x6003009c), helpstring("Returns a string that contains the GridEX control layout settings.")]
        HRESULT LayoutString(
                        [in, out, optional] VARIANT_BOOL* UnicodeCompression, 
                        [out, retval] BSTR* );
        [id(0x6003009d), helpstring("Loads a previously saved GridEX layout from a layout string.")]
        HRESULT LoadLayoutString(
                        [in, out] BSTR* LayoutString, 
                        [in, out, optional] VARIANT_BOOL* Rebind, 
                        [in, out, optional] BSTR* DatabaseName);
        [id(0x6003009e), helpstring("Returns a JSRowData object representing a row.")]
        HRESULT GetRowData(
                        [in] long RowPosition, 
                        [out, retval] _JSRowData** );
    };

