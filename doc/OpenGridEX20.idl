    [
      uuid(8B6FADB1-49AC-4AF0-88B1-16C3C5A826CE),
      version(1.0),
      helpstring("Janus GridEX 2000 Control (DAO 3.6 & ADO 2.x)"),
      hidden,
      nonextensible
    ]
    dispinterface __GridEX {
        properties:
        methods:
            [id(0x00000001), helpstring("Occurs before the user enters edit mode by typing a character or clicking in a cell.")]
            void BeforeColEdit(
                            [in] short ColIndex, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000002), helpstring("Occurs after data in the current cell is edited.")]
            void AfterColEdit([in] short ColIndex);
            [id(0x00000003), helpstring("Occurs before data is moved from the cell to the control's copy buffer.")]
            void BeforeColUpdate(
                            [in] long Row, 
                            [in] short ColIndex, 
                            [in] BSTR OldValue, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000004), helpstring("Occurs as the result of a data access error.")]
            void Error(
                            [in] long ErrNumber, 
                            [in] _JSRetBoolean* DisplayMessage);
            [id(0x00000005), helpstring("Occurs before data is committed from to the database.")]
            void BeforeUpdate([in] _JSRetBoolean* Cancel);
            [id(0x00000006), helpstring("Occurs after data is moved from a cell  to the control's copy buffer.")]
            void AfterColUpdate([in] short ColIndex);
            [id(0x00000007), helpstring("Occurs after changes made by the user have been written to the database.")]
            void AfterUpdate();
            [id(0x00000008), helpstring("Occurs when the contents of the current cell have changed.")]
            void Change();
            [id(0x00000009), helpstring("Occurs when the user clicks on a column header.")]
            void ColumnHeaderClick([in] _JSColumn* Column);
            [id(0x0000000a), helpstring("Occurs when the user clicks on a header in the group by box.")]
            void GroupByBoxHeaderClick([in] _JSGroup* Group);
            [id(0x0000000b), helpstring("Occurs before a column position changes.")]
            void BeforeColMove(
                            [in] _JSColumn* Column, 
                            [in] short NewPosition, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x0000000c), helpstring("Occurs after the user has moved a column into a new position.")]
            void AfterColMove();
            [id(0x0000000d), helpstring("Occurs before the user begins a drag operation with a header in the column headers row.")]
            void BeforeColumnDrag(
                            [in] _JSColumn* Column, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x0000000e), helpstring("Occurs before the user begins a drag operation with a group by box header.")]
            void BeforeGroupDrag(
                            [in] _JSGroup* Group, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x0000000f), helpstring("Occurs after the user has changed, added or removed a group.")]
            void AfterGroupChange();
            [id(0x00000010), helpstring("Occurs before a change in the group settings is committed.")]
            void BeforeGroupChange(
                            [in] _JSGroup* Group, 
                            [in] jgexGroupChange ChangeOperation, 
                            [in] short GroupPosition, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000011), helpstring("Occurs after the user deletes the selected record.")]
            void AfterDelete();
            [id(0x00000012), helpstring("Occurs before a delete operation begins.")]
            void BeforeDelete([in] _JSRetBoolean* Cancel);
            [id(0x00000013), helpstring("Occurs when unbound column data is needed for display.")]
            void FetchData(
                            [in] long RowIndex, 
                            [in] short ColIndex, 
                            [in] VARIANT RowBookmark, 
                            [in] _JSRetVariant* Value);
            [id(0x00000014), helpstring("Fetches the  icons index for cells.")]
            void FetchIcon(
                            [in] long RowIndex, 
                            [in] short ColIndex, 
                            [in] VARIANT RowBookmark, 
                            [in] _JSRetInteger* IconIndex);
            [id(0x00000015), helpstring("Occurs in Unbound mode, whenever a row of data is deleted.")]
            void UnboundDelete(
                            [in] long RowIndex, 
                            [in] VARIANT Bookmark);
            [id(0x00000016), helpstring("Occurs in an unbound GridEX control when a new row is added to it.")]
            void UnboundAddNew(
                            [in] _JSRetVariant* NewRowBookmark, 
                            [in] _JSRowData* Values);
            [id(0x00000017), helpstring("Occurs when an unbound GridEX control has an entire row of modified data to be written in the data set.")]
            void UnboundUpdate(
                            [in] long RowIndex, 
                            [in] VARIANT Bookmark, 
                            [in] _JSRowData* Values);
            [id(0x00000018), helpstring("Occurs when the user presses and then releases a mouse button over the control.")]
            void Click();
            [id(0x00000019), helpstring("Occurs when the user presses and releases a mouse button two times over the control.")]
            void DblClick();
            [id(0x0000001a), helpstring("Occur when the user presses a key.")]
            void KeyDown(
                            [in, out] short* KeyCode, 
                            [in, out] short* Shift);
            [id(0x0000001b), helpstring("Occur when the user releases a key.")]
            void KeyUp(
                            [in, out] short* KeyCode, 
                            [in, out] short* Shift);
            [id(0x0000001c), helpstring("Occurs when the user presses a mouse button.")]
            void MouseDown(
                            [in, out] short* Button, 
                            [in, out] short* Shift, 
                            [in, out] single* X, 
                            [in, out] single* Y);
            [id(0x0000001d), helpstring("Occurs when the user moves the mouse.")]
            void MouseMove(
                            [in, out] short* Button, 
                            [in, out] short* Shift, 
                            [in, out] single* X, 
                            [in, out] single* Y);
            [id(0x0000001e), helpstring("Occurs when the user releases a mouse button.")]
            void MouseUp(
                            [in, out] short* Button, 
                            [in, out] short* Shift, 
                            [in, out] single* X, 
                            [in, out] single* Y);
            [id(0x0000001f), helpstring("Occurs when the user presses and releases an ANSI key.")]
            void KeyPress([in, out] short* KeyAscii);
            [id(0x00000020), helpstring("Occurs when the FirstItem property changes.")]
            void FirstItemChange();
            [id(0x00000021), helpstring("Occurs when the LeftCol property changes.")]
            void LeftColChange();
            [id(0x00000022), helpstring("Occurs when the current cell changes to a different cell.")]
            void RowColChange(
                            [in] long LastRow, 
                            [in] short LastCol);
            [id(0x00000023), helpstring("Occurs when a user resizes a column in a GridEX control.")]
            void ColResize(
                            [in] short ColIndex, 
                            [in] long NewColWidth, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000024), helpstring("Occurs when the user resizes rows.")]
            void RowResize(
                            [in] long NewRowHeight, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000025), helpstring("Occurs when the user resizes cards.")]
            void CardResize(
                            [in] long NewCardWidth, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000026), helpstring("Occurs before a drop down list appears.")]
            void DropList([in] short ColIndex);
            [id(0x00000027), helpstring("Occurs after the user has selected an entry in a drop down list.")]
            void ListSelected(
                            [in] short ColIndex, 
                            [in] long ValueListIndex, 
                            [in] VARIANT Value);
            [id(0x00000028), helpstring("Occurs whenever an unbound GridEX control requires data for display, sorting or grouping.")]
            void UnboundReadData(
                            [in] long RowIndex, 
                            [in] VARIANT Bookmark, 
                            [in] _JSRowData* Values);
            [id(0x00000029), helpstring("Occurs when the user attempts to drag the selected rows.")]
            void RowDrag(
                            [in] short Button, 
                            [in] short Shift);
            [id(0x0000002a), helpstring("Occurs when an edit operation is about to begin.")]
            void InitCustomEdit(
                            [in] short ColIndex, 
                            [in] OLE_COLOR EditBackColor, 
                            [in] OLE_COLOR EditForeColor, 
                            [in] Font* EditFont);
            [id(0x0000002b), helpstring("Occurs when a custom edit column is about to hide or show the cell editor.")]
            void ShowCustomEdit(
                            [in] short ColIndex, 
                            [in] single EditLeft, 
                            [in] single EditTop, 
                            [in] single EditWidth, 
                            [in] single EditHeight, 
                            [in] VARIANT_BOOL EditVisible);
            [id(0x0000002c), helpstring("Occurs when a custom edit operation is ended.")]
            void EndCustomEdit([in] short ColIndex);
            [id(0x0000002d), helpstring("Occurs when a drag action was either performed or canceled.")]
            void OLECompleteDrag([in, out] long* Effect);
            [id(0x0000002e), helpstring("Occurs when the source component determines that a drop can occur.")]
            void OLEDragDrop(
                            [in, out] _JSDataObject** Data, 
                            [in, out] long* Effect, 
                            [in, out] short* Button, 
                            [in, out] short* Shift, 
                            [in, out] single* X, 
                            [in, out] single* Y);
            [id(0x0000002f), helpstring("Occurs when one component is dragged over another.")]
            void OLEDragOver(
                            [in, out] _JSDataObject** Data, 
                            [in, out] long* Effect, 
                            [in, out] short* Button, 
                            [in, out] short* Shift, 
                            [in, out] single* X, 
                            [in, out] single* Y, 
                            [in, out] short* State);
            [id(0x00000030), helpstring("Occurs at the source control of an OLE drag/drop operation when the mouse cursor needs to be changed.")]
            void OLEGiveFeedback(
                            [in, out] long* Effect, 
                            [in, out] VARIANT_BOOL* DefaultCursors);
            [id(0x00000031), helpstring("Occurs on a source component when a target component requests data that was not provided during the OLEStartDrag event.")]
            void OLESetData(
                            [in, out] _JSDataObject** Data, 
                            [in, out] short* DataFormat);
            [id(0x00000032), helpstring("Occurs when the OLEDrag method is performed and, data formats and drop effects need to be specified.")]
            void OLEStartDrag(
                            [in, out] _JSDataObject** Data, 
                            [in, out] long* AllowedEffects);
            [id(0x00000033), helpstring("Occurs before a selected record is deleted in a GridEX control.")]
            void BeforeDeleteEX(
                            [in] long RowIndex, 
                            [in] VARIANT Bookmark, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000034), helpstring("Occurs when the user presses a button in a cell.")]
            void ColButtonClick([in] short ColIndex);
            [id(0x00000035), helpstring("Occurs when The GridEX control loads a row.")]
            void RowFormat([in, out] _JSRowData** RowBuffer);
            [id(0x00000036), helpstring("Occurs before the GridEX control prints its contents.")]
            void BeforePrinting(
                            [in] long nPages, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000037), helpstring("Occurs before the GridEX prints a page.")]
            void BeforePrintPage(
                            [in] long PageNumber, 
                            [in] long nPages);
            [id(0x00000038), helpstring("Occurs continuously while the GridEX control is printing a document.")]
            void PrintingProgress(
                            [in] single PrintProgress, 
                            [in] _JSRetBoolean* Cancel);
            [id(0x00000039), helpstring("Occurs when the text entered by the user in a combo column is not present in the list.")]
            void NotInList(
                            [in] short ColIndex, 
                            [in] BSTR NewData, 
                            [in] _JSRetBoolean* CancelUpdate);
            [id(0x0000003a), helpstring("Occurs when the user selects a different range of rows.")]
            void SelectionChange();
    };

    [
      uuid(7A6D95D1-4F55-4A87-A808-16D390E56957),
      version(1.0),
      helpstring("Janus GridEX 2000 Print Preview Control (DAO 3.6 & ADO 2.x)"),
      hidden,
      nonextensible
    ]
    dispinterface __GEXPreview {
        properties:
        methods:
            [id(0x00000001), helpstring("Occurs when the Close button, in the control's tool bar, has been clicked.")]
            void OnCloseClick();
            [id(0x00000002), helpstring("Occurs when the Print button, in the control's tool bar, has been clicked.")]
            void OnPrintClick([in] _JSRetBoolean* UsePrintSetupDlg);
            [id(0x00000003), helpstring("Occurs before paginating the document.")]
            void BeforePaginating();
            [id(0x00000004), helpstring("Occurs after paginating the document.")]
            void AfterPaginating();
            [id(0x00000005), helpstring("Occurs after the Zoom property changes.")]
            void ZoomChanged();
            [id(0x00000006)]
            void PageChanged();
    };

